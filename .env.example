# Choose one:

# Option A -- local, free, no API key. Requires `ollama serve` running
# and the model already pulled (`ollama pull qwen3:8b`).
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: use a smaller/faster model just for `match` (relevance scoring
# doesn't need as much reasoning as resume tailoring does). Requires
# `ollama pull qwen3:4b` first. Leave unset to use OLLAMA_MODEL for both.
# OLLAMA_MATCH_MODEL=qwen3:4b

# Option B -- OpenAI (comment out LLM_PROVIDER above, or set it to "openai")
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
